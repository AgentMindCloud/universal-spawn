{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://universal-spawn.dev/platforms/creative/obsidian/obsidian-spawn.schema.json",
  "title": "universal-spawn with Obsidian platform extension",
  "allOf": [
    {
      "$ref": "https://universal-spawn.dev/spec/v1.0/universal-spawn.schema.json"
    },
    {
      "type": "object",
      "required": [
        "platforms"
      ],
      "properties": {
        "platforms": {
          "type": "object",
          "required": [
            "obsidian"
          ],
          "properties": {
            "obsidian": {
              "$ref": "#/definitions/obsidian"
            }
          }
        }
      }
    }
  ],
  "definitions": {
    "obsidian": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "plugin",
            "theme",
            "vault-snapshot"
          ]
        },
        "manifest_file": {
          "type": "string"
        },
        "min_app_version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+(\\.[0-9]+)?$"
        },
        "vault_archive": {
          "type": "string"
        },
        "desktop_only": {
          "type": "boolean",
          "default": false
        }
      }
    }
  }
}
