{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://universal-spawn.dev/platforms/creative/cinema4d/cinema4d-spawn.schema.json",
  "title": "universal-spawn with Cinema 4D platform extension",
  "allOf": [
    {
      "$ref": "https://universal-spawn.dev/spec/v1.0/universal-spawn.schema.json"
    },
    {
      "type": "object",
      "required": [
        "platforms"
      ],
      "properties": {
        "platforms": {
          "type": "object",
          "required": [
            "cinema4d"
          ],
          "properties": {
            "cinema4d": {
              "$ref": "#/definitions/cinema4d"
            }
          }
        }
      }
    }
  ],
  "definitions": {
    "cinema4d": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "min_version"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "plugin",
            "scene",
            "asset-library"
          ]
        },
        "min_version": {
          "type": "string",
          "pattern": "^(R|S)?[0-9]+(\\.[0-9]+)?$"
        },
        "entry_file": {
          "type": "string"
        }
      }
    }
  }
}
