{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://universal-spawn.dev/platforms/creative/canva/canva-spawn.schema.json",
  "title": "universal-spawn with Canva platform extension",
  "allOf": [
    {
      "$ref": "https://universal-spawn.dev/spec/v1.0/universal-spawn.schema.json"
    },
    {
      "type": "object",
      "required": [
        "platforms"
      ],
      "properties": {
        "platforms": {
          "type": "object",
          "required": [
            "canva"
          ],
          "properties": {
            "canva": {
              "$ref": "#/definitions/canva"
            }
          }
        }
      }
    }
  ],
  "definitions": {
    "canva": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "app",
            "template",
            "design"
          ]
        },
        "app_json": {
          "type": "string"
        },
        "design_url": {
          "type": "string",
          "format": "uri"
        },
        "design_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_-]{8,64}$"
        },
        "categories": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "surface": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "object-panel",
              "content-panel",
              "publish",
              "editor"
            ]
          }
        }
      }
    }
  }
}
