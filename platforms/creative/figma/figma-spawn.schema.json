{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://universal-spawn.dev/platforms/creative/figma/figma-spawn.schema.json",
  "title": "universal-spawn with Figma platform extension",
  "allOf": [
    {
      "$ref": "https://universal-spawn.dev/spec/v1.0/universal-spawn.schema.json"
    },
    {
      "type": "object",
      "required": [
        "platforms"
      ],
      "properties": {
        "platforms": {
          "type": "object",
          "required": [
            "figma"
          ],
          "properties": {
            "figma": {
              "$ref": "#/definitions/figma"
            }
          }
        }
      }
    }
  ],
  "definitions": {
    "figma": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "plugin",
            "widget",
            "template"
          ]
        },
        "manifest_file": {
          "type": "string"
        },
        "editor_type": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "figma",
              "figjam",
              "dev",
              "slides"
            ]
          }
        },
        "network_access": {
          "type": "string",
          "enum": [
            "none",
            "declared",
            "allowed-hosts"
          ]
        },
        "allowed_hosts": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "hostname"
          }
        },
        "capabilities": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "textreview",
              "inspect",
              "vscode",
              "codegen"
            ]
          }
        },
        "community_file": {
          "type": "string",
          "description": "Community-file URL or numeric id for kind=template."
        }
      }
    }
  }
}
