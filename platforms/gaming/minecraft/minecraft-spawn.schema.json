{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://universal-spawn.dev/platforms/gaming/minecraft/minecraft-spawn.schema.json",
  "title": "universal-spawn with Minecraft platform extension",
  "allOf": [
    {
      "$ref": "https://universal-spawn.dev/spec/v1.0/universal-spawn.schema.json"
    },
    {
      "type": "object",
      "required": [
        "platforms"
      ],
      "properties": {
        "platforms": {
          "type": "object",
          "required": [
            "minecraft"
          ],
          "properties": {
            "minecraft": {
              "$ref": "#/definitions/minecraft"
            }
          }
        }
      }
    }
  ],
  "definitions": {
    "minecraft": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "minecraft_version"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "datapack",
            "mod"
          ]
        },
        "minecraft_version": {
          "type": "string",
          "pattern": "^[0-9]+(\\.[0-9]+)+(-[a-z0-9.]+)?(,[ ]*[0-9]+(\\.[0-9]+)+)?$"
        },
        "loader": {
          "type": "string",
          "enum": [
            "fabric",
            "forge",
            "neoforge",
            "quilt"
          ]
        },
        "pack_format": {
          "type": "integer",
          "minimum": 1,
          "maximum": 99
        },
        "distribution": {
          "type": "string",
          "enum": [
            "curseforge",
            "modrinth",
            "both"
          ]
        },
        "curseforge_id": {
          "type": "string",
          "pattern": "^[0-9]{4,10}$"
        },
        "modrinth_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9]{6,16}$"
        }
      }
    }
  }
}
