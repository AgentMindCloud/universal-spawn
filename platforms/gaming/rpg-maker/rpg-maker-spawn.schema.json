{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://universal-spawn.dev/platforms/gaming/rpg-maker/rpg-maker-spawn.schema.json",
  "title": "universal-spawn with RPG Maker platform extension",
  "allOf": [
    {
      "$ref": "https://universal-spawn.dev/spec/v1.0/universal-spawn.schema.json"
    },
    {
      "type": "object",
      "required": [
        "platforms"
      ],
      "properties": {
        "platforms": {
          "type": "object",
          "required": [
            "rpg-maker"
          ],
          "properties": {
            "rpg-maker": {
              "$ref": "#/definitions/rpg-maker"
            }
          }
        }
      }
    }
  ],
  "definitions": {
    "rpg-maker": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "engine",
        "kind"
      ],
      "properties": {
        "engine": {
          "type": "string",
          "enum": [
            "mv",
            "mz",
            "unite"
          ]
        },
        "kind": {
          "type": "string",
          "enum": [
            "project",
            "plugin"
          ]
        },
        "entry_data_dir": {
          "type": "string"
        },
        "plugin_file": {
          "type": "string"
        }
      }
    }
  }
}
