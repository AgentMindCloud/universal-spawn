{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://universal-spawn.dev/platforms/gaming/playcanvas/playcanvas-spawn.schema.json",
  "title": "universal-spawn with PlayCanvas platform extension",
  "allOf": [
    {
      "$ref": "https://universal-spawn.dev/spec/v1.0/universal-spawn.schema.json"
    },
    {
      "type": "object",
      "required": [
        "platforms"
      ],
      "properties": {
        "platforms": {
          "type": "object",
          "required": [
            "playcanvas"
          ],
          "properties": {
            "playcanvas": {
              "$ref": "#/definitions/playcanvas"
            }
          }
        }
      }
    }
  ],
  "definitions": {
    "playcanvas": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "project_id"
      ],
      "properties": {
        "project_id": {
          "type": "string",
          "pattern": "^[0-9]{4,12}$"
        },
        "scene_id": {
          "type": "string",
          "pattern": "^[0-9]{4,12}$"
        },
        "engine_version": {
          "type": "string",
          "pattern": "^[0-9]+(\\.[0-9]+)+$"
        },
        "editor_url": {
          "type": "string",
          "format": "uri"
        }
      }
    }
  }
}
