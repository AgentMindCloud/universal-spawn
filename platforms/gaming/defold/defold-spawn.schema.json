{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://universal-spawn.dev/platforms/gaming/defold/defold-spawn.schema.json",
  "title": "universal-spawn with Defold platform extension",
  "allOf": [
    {
      "$ref": "https://universal-spawn.dev/spec/v1.0/universal-spawn.schema.json"
    },
    {
      "type": "object",
      "required": [
        "platforms"
      ],
      "properties": {
        "platforms": {
          "type": "object",
          "required": [
            "defold"
          ],
          "properties": {
            "defold": {
              "$ref": "#/definitions/defold"
            }
          }
        }
      }
    }
  ],
  "definitions": {
    "defold": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "engine_version"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "project",
            "extension"
          ]
        },
        "engine_version": {
          "type": "string",
          "pattern": "^[0-9]+(\\.[0-9]+)+$"
        },
        "target_platforms": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "windows",
              "macos",
              "linux",
              "ios",
              "android",
              "html5",
              "switch"
            ]
          }
        },
        "entry_collection": {
          "type": "string"
        }
      }
    }
  }
}
