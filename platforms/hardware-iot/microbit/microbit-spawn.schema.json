{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://universal-spawn.dev/platforms/hardware-iot/microbit/microbit-spawn.schema.json",
  "title": "universal-spawn with micro:bit platform extension",
  "allOf": [
    {
      "$ref": "https://universal-spawn.dev/spec/v1.0/universal-spawn.schema.json"
    },
    {
      "type": "object",
      "required": [
        "platforms"
      ],
      "properties": {
        "platforms": {
          "type": "object",
          "required": [
            "microbit"
          ],
          "properties": {
            "microbit": {
              "$ref": "#/definitions/microbit"
            }
          }
        }
      }
    }
  ],
  "definitions": {
    "microbit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "variant",
        "toolchain"
      ],
      "properties": {
        "variant": {
          "type": "string",
          "enum": [
            "v1",
            "v2"
          ]
        },
        "toolchain": {
          "type": "string",
          "enum": [
            "makecode",
            "micropython"
          ]
        },
        "entry_file": {
          "type": "string"
        },
        "makecode_share_url": {
          "type": "string",
          "format": "uri"
        }
      }
    }
  }
}
