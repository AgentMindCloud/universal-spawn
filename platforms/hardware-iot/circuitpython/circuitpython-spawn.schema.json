{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://universal-spawn.dev/platforms/hardware-iot/circuitpython/circuitpython-spawn.schema.json",
  "title": "universal-spawn with CircuitPython platform extension",
  "allOf": [
    {
      "$ref": "https://universal-spawn.dev/spec/v1.0/universal-spawn.schema.json"
    },
    {
      "type": "object",
      "required": [
        "platforms"
      ],
      "properties": {
        "platforms": {
          "type": "object",
          "required": [
            "circuitpython"
          ],
          "properties": {
            "circuitpython": {
              "$ref": "#/definitions/circuitpython"
            }
          }
        }
      }
    }
  ],
  "definitions": {
    "circuitpython": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "board"
      ],
      "properties": {
        "board": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_-]+$"
        },
        "entry_script": {
          "type": "string"
        },
        "bundle_libraries": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
