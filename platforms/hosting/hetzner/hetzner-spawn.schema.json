{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://universal-spawn.dev/platforms/hosting/hetzner/hetzner-spawn.schema.json",
  "title": "universal-spawn with Hetzner Cloud platform extension",
  "allOf": [
    {
      "$ref": "https://universal-spawn.dev/spec/v1.0/universal-spawn.schema.json"
    },
    {
      "type": "object",
      "required": [
        "platforms"
      ],
      "properties": {
        "platforms": {
          "type": "object",
          "required": [
            "hetzner"
          ],
          "properties": {
            "hetzner": {
              "$ref": "#/definitions/hetzner"
            }
          }
        }
      }
    }
  ],
  "definitions": {
    "hetzner": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "location",
        "server_type",
        "image"
      ],
      "properties": {
        "location": {
          "type": "string",
          "enum": [
            "fsn1",
            "nbg1",
            "hel1",
            "ash",
            "hil",
            "sin"
          ]
        },
        "server_type": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]{1,31}$"
        },
        "image": {
          "type": "string"
        },
        "ssh_keys": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "cloud_init": {
          "type": "string"
        },
        "volumes": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "size_gb"
            ],
            "properties": {
              "name": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9-]{0,63}$"
              },
              "size_gb": {
                "type": "integer",
                "minimum": 10,
                "maximum": 10240
              },
              "mount": {
                "type": "string"
              }
            }
          }
        },
        "networks": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]{0,63}$"
          }
        },
        "firewall_rules": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "direction",
              "protocol"
            ],
            "properties": {
              "direction": {
                "type": "string",
                "enum": [
                  "in",
                  "out"
                ]
              },
              "protocol": {
                "type": "string",
                "enum": [
                  "tcp",
                  "udp",
                  "icmp"
                ]
              },
              "port_range": {
                "type": "string"
              },
              "source_cidrs": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  }
}
