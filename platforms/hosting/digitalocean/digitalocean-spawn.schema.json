{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://universal-spawn.dev/platforms/hosting/digitalocean/digitalocean-spawn.schema.json",
  "title": "universal-spawn with DigitalOcean platform extension",
  "allOf": [
    {
      "$ref": "https://universal-spawn.dev/spec/v1.0/universal-spawn.schema.json"
    },
    {
      "type": "object",
      "required": [
        "platforms"
      ],
      "properties": {
        "platforms": {
          "type": "object",
          "required": [
            "digitalocean"
          ],
          "properties": {
            "digitalocean": {
              "$ref": "#/definitions/digitalocean"
            }
          }
        }
      }
    }
  ],
  "definitions": {
    "digitalocean": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface",
        "region"
      ],
      "properties": {
        "surface": {
          "type": "string",
          "enum": [
            "app_platform",
            "functions"
          ]
        },
        "region": {
          "type": "string",
          "enum": [
            "nyc",
            "ams",
            "sfo",
            "fra",
            "tor",
            "lon",
            "blr",
            "sgp",
            "syd"
          ]
        },
        "services": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "kind"
            ],
            "properties": {
              "name": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9-]{0,63}$"
              },
              "kind": {
                "type": "string",
                "enum": [
                  "web",
                  "worker",
                  "job",
                  "static_site"
                ]
              },
              "instance_size": {
                "type": "string",
                "enum": [
                  "basic-xxs",
                  "basic-xs",
                  "basic-s",
                  "basic-m",
                  "professional-xs",
                  "professional-s",
                  "professional-m",
                  "professional-l"
                ]
              },
              "instance_count": {
                "type": "integer",
                "minimum": 0,
                "maximum": 100
              },
              "build_command": {
                "type": "string"
              },
              "run_command": {
                "type": "string"
              },
              "http_port": {
                "type": "integer",
                "minimum": 1,
                "maximum": 65535
              }
            }
          }
        },
        "databases": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "engine"
            ],
            "properties": {
              "name": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9-]{0,63}$"
              },
              "engine": {
                "type": "string",
                "enum": [
                  "PG",
                  "MYSQL",
                  "REDIS",
                  "MONGODB"
                ]
              },
              "size": {
                "type": "string",
                "enum": [
                  "db-s-dev",
                  "db-s-1vcpu-1gb",
                  "db-s-1vcpu-2gb",
                  "db-s-2vcpu-4gb"
                ]
              }
            }
          }
        },
        "functions": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "runtime": {
              "type": "string",
              "enum": [
                "nodejs:20",
                "python:3.11",
                "go:1.22"
              ]
            },
            "package": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
