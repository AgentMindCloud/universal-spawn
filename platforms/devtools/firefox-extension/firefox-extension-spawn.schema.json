{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://universal-spawn.dev/platforms/devtools/firefox-extension/firefox-extension-spawn.schema.json",
  "title": "universal-spawn with Firefox Extension platform extension",
  "allOf": [
    {
      "$ref": "https://universal-spawn.dev/spec/v1.0/universal-spawn.schema.json"
    },
    {
      "type": "object",
      "required": [
        "platforms"
      ],
      "properties": {
        "platforms": {
          "type": "object",
          "required": [
            "firefox-extension"
          ],
          "properties": {
            "firefox-extension": {
              "$ref": "#/definitions/firefox-extension"
            }
          }
        }
      }
    }
  ],
  "definitions": {
    "firefox-extension": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "manifest_version"
      ],
      "properties": {
        "manifest_version": {
          "type": "integer",
          "enum": [
            2,
            3
          ]
        },
        "amo_slug": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]{0,63}$"
        },
        "gecko_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._-]+@[A-Za-z0-9._-]+$"
        },
        "permissions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "host_permissions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "background_script": {
          "type": "string"
        },
        "strict_min_version": {
          "type": "string",
          "pattern": "^[0-9]+(\\.[0-9]+)*$"
        }
      }
    }
  }
}
