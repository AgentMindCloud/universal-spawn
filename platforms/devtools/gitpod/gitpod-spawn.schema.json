{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://universal-spawn.dev/platforms/devtools/gitpod/gitpod-spawn.schema.json",
  "title": "universal-spawn with Gitpod platform extension",
  "allOf": [
    {
      "$ref": "https://universal-spawn.dev/spec/v1.0/universal-spawn.schema.json"
    },
    {
      "type": "object",
      "required": [
        "platforms"
      ],
      "properties": {
        "platforms": {
          "type": "object",
          "required": [
            "gitpod"
          ],
          "properties": {
            "gitpod": {
              "$ref": "#/definitions/gitpod"
            }
          }
        }
      }
    }
  ],
  "definitions": {
    "gitpod": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "image": {
          "type": "string"
        },
        "tasks": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string"
              },
              "init": {
                "type": "string"
              },
              "command": {
                "type": "string"
              },
              "before": {
                "type": "string"
              }
            }
          }
        },
        "ports": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "port"
            ],
            "properties": {
              "port": {
                "type": "integer",
                "minimum": 1,
                "maximum": 65535
              },
              "visibility": {
                "type": "string",
                "enum": [
                  "private",
                  "public",
                  "org"
                ]
              },
              "on_open": {
                "type": "string",
                "enum": [
                  "open-browser",
                  "open-preview",
                  "notify",
                  "ignore"
                ]
              }
            }
          }
        },
        "tier": {
          "type": "string",
          "enum": [
            "small",
            "standard",
            "large",
            "x-large"
          ]
        },
        "tools": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "vscode",
              "ssh",
              "jetbrains"
            ]
          }
        }
      }
    }
  }
}
