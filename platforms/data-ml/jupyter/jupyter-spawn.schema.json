{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://universal-spawn.dev/platforms/data-ml/jupyter/jupyter-spawn.schema.json",
  "title": "universal-spawn with Jupyter platform extension",
  "allOf": [
    {
      "$ref": "https://universal-spawn.dev/spec/v1.0/universal-spawn.schema.json"
    },
    {
      "type": "object",
      "required": [
        "platforms"
      ],
      "properties": {
        "platforms": {
          "type": "object",
          "required": [
            "jupyter"
          ],
          "properties": {
            "jupyter": {
              "$ref": "#/definitions/jupyter"
            }
          }
        }
      }
    }
  ],
  "definitions": {
    "jupyter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "notebook-project",
            "lab-extension"
          ]
        },
        "entry_notebook": {
          "type": "string"
        },
        "requirements": {
          "type": "string"
        },
        "kernel": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]{0,63}$"
        },
        "lab_extension_id": {
          "type": "string",
          "pattern": "^@[a-z0-9-][a-z0-9_.-]*/[a-z0-9-][a-z0-9_.-]*$"
        }
      }
    }
  }
}
