{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://universal-spawn.dev/platforms/social/x-twitter/x-twitter-spawn.schema.json",
  "title": "universal-spawn with X (Twitter) platform extension",
  "allOf": [
    {
      "$ref": "https://universal-spawn.dev/spec/v1.0/universal-spawn.schema.json"
    },
    {
      "type": "object",
      "required": [
        "platforms"
      ],
      "properties": {
        "platforms": {
          "type": "object",
          "required": [
            "x-twitter"
          ],
          "properties": {
            "x-twitter": {
              "$ref": "#/definitions/x-twitter"
            }
          }
        }
      }
    }
  ],
  "definitions": {
    "x-twitter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "account",
        "scopes",
        "tier"
      ],
      "properties": {
        "account": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_]{1,15}$"
        },
        "scopes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "tweet.read",
              "tweet.write",
              "users.read",
              "follows.read",
              "follows.write",
              "offline.access",
              "space.read",
              "mute.read",
              "mute.write",
              "like.read",
              "like.write",
              "list.read",
              "list.write",
              "block.read",
              "block.write",
              "bookmark.read",
              "bookmark.write",
              "dm.read",
              "dm.write"
            ]
          }
        },
        "tier": {
          "type": "string",
          "enum": [
            "free",
            "basic",
            "pro",
            "enterprise"
          ]
        },
        "streams": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "uses_grok": {
          "type": "boolean",
          "default": false
        }
      }
    }
  }
}
