{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://universal-spawn.dev/platforms/ai/claude/claude-spawn.schema.json",
  "title": "universal-spawn with Claude (Anthropic) platform extension",
  "description": "Strict draft-07 extension for the Claude platform. Composes with the master v1.0 schema via allOf.",

  "allOf": [
    { "$ref": "https://universal-spawn.dev/spec/v1.0/universal-spawn.schema.json" },
    {
      "type": "object",
      "required": ["platforms"],
      "properties": {
        "platforms": {
          "type": "object",
          "required": ["claude"],
          "properties": {
            "claude": { "$ref": "#/definitions/claude" }
          }
        }
      }
    }
  ],

  "definitions": {
    "claude": {
      "type": "object",
      "additionalProperties": false,
      "required": ["skill_type", "surface"],
      "properties": {
        "skill_type": {
          "type": "string",
          "enum": ["skill", "subagent", "tool", "mcp", "slash-command", "computer-use"]
        },
        "skill_file": {
          "type": "string",
          "description": "Relative path to the Skill definition file (YAML) when skill_type is 'skill'."
        },
        "model": {
          "type": "string",
          "enum": ["claude-opus-4-7", "claude-sonnet-4-6", "claude-haiku-4-5-20251001"]
        },
        "surface": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["claude-api", "claude-code", "claude-app", "claude-mcp", "claude-chrome"]
          }
        },
        "tools": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "function_ref"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string", "pattern": "^[a-zA-Z][a-zA-Z0-9_-]{0,63}$" },
              "function_ref": { "type": "string" }
            }
          }
        },
        "mcp_server": {
          "type": "object",
          "additionalProperties": false,
          "required": ["transport"],
          "properties": {
            "transport": { "type": "string", "enum": ["stdio", "http", "websocket"] },
            "ref": { "type": "string" },
            "command": { "type": "string" },
            "args": { "type": "array", "items": { "type": "string" } }
          }
        },
        "slash_command": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "name": { "type": "string", "pattern": "^[a-z][a-z0-9-]{0,31}$" },
            "file": { "type": "string" },
            "description": { "type": "string", "maxLength": 200 }
          }
        },
        "computer_use": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "viewport": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "width":  { "type": "integer", "minimum": 320, "maximum": 3840 },
                "height": { "type": "integer", "minimum": 240, "maximum": 2160 }
              }
            },
            "allowed_urls": {
              "type": "array",
              "items": { "type": "string", "format": "uri" }
            },
            "max_actions_per_turn": { "type": "integer", "minimum": 1, "maximum": 200 },
            "chrome_integration": { "type": "boolean", "default": false }
          }
        },
        "system_prompt_file": { "type": "string" },
        "prompt_cache": { "type": "boolean", "default": false },
        "thinking": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "type": { "type": "string", "enum": ["enabled", "disabled"] },
            "budget_tokens": { "type": "integer", "minimum": 1024 }
          }
        }
      }
    }
  }
}
