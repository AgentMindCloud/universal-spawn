{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://universal-spawn.dev/platforms/ai/./anthropic-mcp/anthropic-mcp-spawn.schema.json",
  "title": "universal-spawn with Anthropic MCP platform extension",
  "allOf": [
    {
      "$ref": "https://universal-spawn.dev/spec/v1.0/universal-spawn.schema.json"
    },
    {
      "type": "object",
      "required": [
        "platforms"
      ],
      "properties": {
        "platforms": {
          "type": "object",
          "required": [
            "anthropic-mcp"
          ],
          "properties": {
            "anthropic-mcp": {
              "$ref": "#/definitions/anthropic-mcp"
            }
          }
        }
      }
    }
  ],
  "definitions": {
    "anthropic-mcp": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "transport"
      ],
      "properties": {
        "transport": {
          "type": "string",
          "enum": [
            "stdio",
            "http",
            "websocket"
          ]
        },
        "command": {
          "type": "string",
          "description": "Command to launch the server (stdio transport)."
        },
        "args": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "url": {
          "type": "string",
          "description": "Endpoint URL (http / websocket transport)."
        },
        "resources": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "uri_template"
            ],
            "properties": {
              "uri_template": {
                "type": "string"
              },
              "description": {
                "type": "string"
              }
            }
          }
        },
        "prompts": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name"
            ],
            "properties": {
              "name": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9_-]{0,63}$"
              },
              "description": {
                "type": "string"
              }
            }
          }
        },
        "tools": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name"
            ],
            "properties": {
              "name": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9_-]{0,63}$"
              },
              "description": {
                "type": "string"
              },
              "input_schema_ref": {
                "type": "string"
              }
            }
          }
        },
        "hosts": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "claude-desktop",
              "claude-code",
              "cursor",
              "windsurf",
              "zed",
              "continue",
              "cline",
              "any"
            ]
          }
        }
      }
    }
  }
}
