{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://universal-spawn.dev/platforms/ai/./cohere/cohere-spawn.schema.json",
  "title": "universal-spawn with Cohere platform extension",
  "allOf": [
    {
      "$ref": "https://universal-spawn.dev/spec/v1.0/universal-spawn.schema.json"
    },
    {
      "type": "object",
      "required": [
        "platforms"
      ],
      "properties": {
        "platforms": {
          "type": "object",
          "required": [
            "cohere"
          ],
          "properties": {
            "cohere": {
              "$ref": "#/definitions/cohere"
            }
          }
        }
      }
    }
  ],
  "definitions": {
    "cohere": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model"
      ],
      "properties": {
        "model": {
          "type": "string",
          "enum": [
            "command-a-03-2025",
            "command-r-plus-08-2024",
            "command-r-08-2024",
            "command-r7b-12-2024"
          ]
        },
        "tools": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "function_ref"
            ],
            "properties": {
              "name": {
                "type": "string",
                "pattern": "^[a-zA-Z][a-zA-Z0-9_-]{0,63}$"
              },
              "function_ref": {
                "type": "string",
                "description": "Relative path to the tool definition JSON."
              },
              "strict": {
                "type": "boolean",
                "default": false
              }
            }
          }
        },
        "compass": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "index_id"
          ],
          "properties": {
            "index_id": {
              "type": "string"
            },
            "top_k": {
              "type": "integer",
              "minimum": 1,
              "maximum": 50
            }
          }
        },
        "connectors": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "web-search",
              "database",
              "document"
            ]
          }
        },
        "grounded_generations": {
          "type": "boolean",
          "default": false
        },
        "safety_mode": {
          "type": "string",
          "enum": [
            "CONTEXTUAL",
            "STRICT",
            "NONE"
          ]
        },
        "system_prompt_file": {
          "type": "string"
        },
        "temperature": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    }
  }
}
