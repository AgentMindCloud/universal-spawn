{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://universal-spawn.dev/platforms/ai/./together-ai/together-ai-spawn.schema.json",
  "title": "universal-spawn with Together AI platform extension",
  "allOf": [
    {
      "$ref": "https://universal-spawn.dev/spec/v1.0/universal-spawn.schema.json"
    },
    {
      "type": "object",
      "required": [
        "platforms"
      ],
      "properties": {
        "platforms": {
          "type": "object",
          "required": [
            "together-ai"
          ],
          "properties": {
            "together-ai": {
              "$ref": "#/definitions/together-ai"
            }
          }
        }
      }
    }
  ],
  "definitions": {
    "together-ai": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model",
        "surface"
      ],
      "properties": {
        "model": {
          "type": "string",
          "pattern": "^[A-Za-z0-9./_-]+$",
          "description": "Together catalogue id, e.g. meta-llama/Llama-3.3-70B-Instruct-Turbo."
        },
        "surface": {
          "type": "string",
          "enum": [
            "chat",
            "images",
            "embeddings"
          ]
        },
        "tools": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "function_ref"
            ],
            "properties": {
              "name": {
                "type": "string",
                "pattern": "^[a-zA-Z][a-zA-Z0-9_-]{0,63}$"
              },
              "function_ref": {
                "type": "string",
                "description": "Relative path to the tool definition JSON."
              },
              "strict": {
                "type": "boolean",
                "default": false
              }
            }
          }
        },
        "response_format": {
          "type": "string",
          "enum": [
            "text",
            "json_object"
          ]
        },
        "image": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "size": {
              "type": "string",
              "enum": [
                "512x512",
                "1024x1024",
                "1024x1792",
                "1792x1024"
              ]
            },
            "steps": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            },
            "guidance_scale": {
              "type": "number",
              "minimum": 0,
              "maximum": 20
            },
            "n": {
              "type": "integer",
              "minimum": 1,
              "maximum": 4
            }
          }
        },
        "temperature": {
          "type": "number",
          "minimum": 0,
          "maximum": 2
        },
        "max_tokens": {
          "type": "integer",
          "minimum": 1
        },
        "system_prompt_file": {
          "type": "string"
        }
      }
    }
  }
}
