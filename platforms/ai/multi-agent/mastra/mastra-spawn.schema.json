{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://universal-spawn.dev/platforms/ai/multi-agent/mastra/mastra-spawn.schema.json",
  "title": "universal-spawn with Mastra platform extension",
  "allOf": [
    {
      "$ref": "https://universal-spawn.dev/spec/v1.0/universal-spawn.schema.json"
    },
    {
      "type": "object",
      "required": [
        "platforms"
      ],
      "properties": {
        "platforms": {
          "type": "object",
          "required": [
            "mastra"
          ],
          "properties": {
            "mastra": {
              "$ref": "#/definitions/mastra"
            }
          }
        }
      }
    }
  ],
  "definitions": {
    "mastra": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "agents": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "model"
            ],
            "properties": {
              "name": {
                "type": "string",
                "pattern": "^[a-z][a-zA-Z0-9_-]{0,63}$"
              },
              "model": {
                "type": "string",
                "description": "Vercel-AI-SDK-style model id, e.g. anthropic/claude-sonnet-4-6."
              },
              "instructions_file": {
                "type": "string"
              },
              "tools": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "memory": {
                "type": "boolean",
                "default": false
              }
            }
          }
        },
        "workflows": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "entry"
            ],
            "properties": {
              "name": {
                "type": "string",
                "pattern": "^[a-z][a-zA-Z0-9_-]{0,63}$"
              },
              "entry": {
                "type": "string",
                "description": "Entry step id."
              },
              "schema_ref": {
                "type": "string",
                "description": "Relative path to the workflow state zod schema."
              }
            }
          }
        },
        "memory": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "store": {
              "type": "string",
              "enum": [
                "libsql",
                "pg",
                "upstash-redis"
              ]
            },
            "url_env": {
              "type": "string",
              "pattern": "^[A-Z][A-Z0-9_]*$"
            }
          }
        },
        "telemetry": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "otlp_endpoint_env": {
              "type": "string",
              "pattern": "^[A-Z][A-Z0-9_]*$"
            }
          }
        },
        "deploy": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "runtime": {
              "type": "string",
              "enum": [
                "nextjs",
                "vercel-edge",
                "cloudflare",
                "node"
              ]
            }
          }
        }
      }
    }
  }
}
