{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://universal-spawn.dev/platforms/ai/multi-agent/semantic-kernel/semantic-kernel-spawn.schema.json",
  "title": "universal-spawn with Semantic Kernel (Microsoft) platform extension",
  "allOf": [
    {
      "$ref": "https://universal-spawn.dev/spec/v1.0/universal-spawn.schema.json"
    },
    {
      "type": "object",
      "required": [
        "platforms"
      ],
      "properties": {
        "platforms": {
          "type": "object",
          "required": [
            "semantic-kernel"
          ],
          "properties": {
            "semantic-kernel": {
              "$ref": "#/definitions/semantic-kernel"
            }
          }
        }
      }
    }
  ],
  "definitions": {
    "semantic-kernel": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "language",
        "connector",
        "model"
      ],
      "properties": {
        "language": {
          "type": "string",
          "enum": [
            "csharp",
            "python",
            "java"
          ]
        },
        "connector": {
          "type": "string",
          "enum": [
            "openai",
            "azure-openai",
            "huggingface",
            "ollama",
            "local"
          ]
        },
        "model": {
          "type": "string"
        },
        "endpoint_url": {
          "type": "string"
        },
        "skills": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "kind"
            ],
            "properties": {
              "name": {
                "type": "string",
                "pattern": "^[A-Za-z][A-Za-z0-9_]{0,63}$"
              },
              "kind": {
                "type": "string",
                "enum": [
                  "native",
                  "prompt",
                  "openapi"
                ]
              },
              "path": {
                "type": "string",
                "description": "Relative path to the skill directory or OpenAPI file."
              }
            }
          }
        },
        "planner": {
          "type": "string",
          "enum": [
            "function-calling",
            "handlebars",
            "sequential",
            "none"
          ]
        },
        "memory": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "store": {
              "type": "string",
              "enum": [
                "volatile",
                "chroma",
                "pinecone",
                "azure-cognitive-search"
              ]
            }
          }
        }
      }
    }
  }
}
