{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://universal-spawn.dev/platforms/ai/multi-agent/langgraph/langgraph-spawn.schema.json",
  "title": "universal-spawn with LangGraph platform extension",
  "allOf": [
    {
      "$ref": "https://universal-spawn.dev/spec/v1.0/universal-spawn.schema.json"
    },
    {
      "type": "object",
      "required": [
        "platforms"
      ],
      "properties": {
        "platforms": {
          "type": "object",
          "required": [
            "langgraph"
          ],
          "properties": {
            "langgraph": {
              "$ref": "#/definitions/langgraph"
            }
          }
        }
      }
    }
  ],
  "definitions": {
    "langgraph": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "language",
        "entry_graph",
        "nodes"
      ],
      "properties": {
        "language": {
          "type": "string",
          "enum": [
            "python",
            "typescript"
          ]
        },
        "entry_graph": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "file",
            "symbol"
          ],
          "properties": {
            "file": {
              "type": "string"
            },
            "symbol": {
              "type": "string",
              "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
            }
          }
        },
        "state_schema_ref": {
          "type": "string"
        },
        "nodes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name"
            ],
            "properties": {
              "name": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9_-]{0,63}$"
              },
              "kind": {
                "type": "string",
                "enum": [
                  "agent",
                  "tool",
                  "router",
                  "reducer",
                  "human"
                ]
              },
              "llm": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "provider": {
                    "type": "string",
                    "enum": [
                      "openai",
                      "anthropic",
                      "google",
                      "mistral",
                      "cohere",
                      "local"
                    ]
                  },
                  "model": {
                    "type": "string"
                  }
                }
              },
              "tools": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "from"
            ],
            "properties": {
              "from": {
                "type": "string"
              },
              "to": {
                "type": "string"
              },
              "conditional_ref": {
                "type": "string",
                "description": "Relative path to a conditional routing function."
              }
            }
          }
        },
        "checkpoint": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "store": {
              "type": "string",
              "enum": [
                "memory",
                "sqlite",
                "postgres",
                "redis"
              ]
            },
            "dsn_env": {
              "type": "string",
              "pattern": "^[A-Z][A-Z0-9_]*$"
            }
          }
        },
        "interrupt": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "before": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "after": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}
