{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://universal-spawn.dev/platforms/ai/multi-agent/litellm/litellm-spawn.schema.json",
  "title": "universal-spawn with LiteLLM platform extension",
  "allOf": [
    {
      "$ref": "https://universal-spawn.dev/spec/v1.0/universal-spawn.schema.json"
    },
    {
      "type": "object",
      "required": [
        "platforms"
      ],
      "properties": {
        "platforms": {
          "type": "object",
          "required": [
            "litellm"
          ],
          "properties": {
            "litellm": {
              "$ref": "#/definitions/litellm"
            }
          }
        }
      }
    }
  ],
  "definitions": {
    "litellm": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "model_list"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "proxy",
            "library"
          ]
        },
        "model_list": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "model_name",
              "litellm_params"
            ],
            "properties": {
              "model_name": {
                "type": "string"
              },
              "litellm_params": {
                "type": "object",
                "additionalProperties": true,
                "required": [
                  "model"
                ],
                "properties": {
                  "model": {
                    "type": "string"
                  },
                  "api_base": {
                    "type": "string"
                  },
                  "api_key_env": {
                    "type": "string",
                    "pattern": "^[A-Z][A-Z0-9_]*$"
                  },
                  "rpm": {
                    "type": "integer",
                    "minimum": 1
                  }
                }
              }
            }
          }
        },
        "fallbacks": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "router": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "routing_strategy": {
              "type": "string",
              "enum": [
                "simple-shuffle",
                "least-busy",
                "usage-based-routing"
              ]
            },
            "allowed_fails": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "cache": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "redis",
                "memory",
                "disk",
                "none"
              ]
            },
            "redis_url_env": {
              "type": "string",
              "pattern": "^[A-Z][A-Z0-9_]*$"
            },
            "ttl_seconds": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "budget": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "max_budget_usd": {
              "type": "number",
              "minimum": 0
            },
            "reset_period": {
              "type": "string",
              "enum": [
                "daily",
                "weekly",
                "monthly"
              ]
            }
          }
        }
      }
    }
  }
}
