{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://universal-spawn.dev/platforms/ai/./fireworks/fireworks-spawn.schema.json",
  "title": "universal-spawn with Fireworks AI platform extension",
  "allOf": [
    {
      "$ref": "https://universal-spawn.dev/spec/v1.0/universal-spawn.schema.json"
    },
    {
      "type": "object",
      "required": [
        "platforms"
      ],
      "properties": {
        "platforms": {
          "type": "object",
          "required": [
            "fireworks"
          ],
          "properties": {
            "fireworks": {
              "$ref": "#/definitions/fireworks"
            }
          }
        }
      }
    }
  ],
  "definitions": {
    "fireworks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model"
      ],
      "properties": {
        "model": {
          "type": "string",
          "pattern": "^accounts/[a-z0-9-]+/models/[A-Za-z0-9._-]+$",
          "description": "Fireworks catalogue path."
        },
        "fire_function": {
          "type": "boolean",
          "default": false
        },
        "tools": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "function_ref"
            ],
            "properties": {
              "name": {
                "type": "string",
                "pattern": "^[a-zA-Z][a-zA-Z0-9_-]{0,63}$"
              },
              "function_ref": {
                "type": "string",
                "description": "Relative path to the tool definition JSON."
              },
              "strict": {
                "type": "boolean",
                "default": false
              }
            }
          }
        },
        "response_format": {
          "type": "string",
          "enum": [
            "text",
            "json_object",
            "json_schema"
          ]
        },
        "response_schema_ref": {
          "type": "string"
        },
        "temperature": {
          "type": "number",
          "minimum": 0,
          "maximum": 2
        },
        "max_tokens": {
          "type": "integer",
          "minimum": 1
        },
        "system_prompt_file": {
          "type": "string"
        }
      }
    }
  }
}
