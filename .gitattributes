# Default: auto-detect text, always LF in the repo
* text=auto eol=lf

# Specification / manifest sources
*.md          text diff=markdown
*.yaml        text
*.yml         text
*.json        text
*.toml        text

# Schemas — linguist treats these as JSON
*.schema.json linguist-language=JSON
*.schema.yaml linguist-language=YAML

# YAML should count in repo language stats
*.yaml        linguist-detectable=true
*.yml         linguist-detectable=true

# Script files keep LF
*.sh          text eol=lf
*.py          text eol=lf

# Binary assets
*.png         binary
*.jpg         binary
*.jpeg        binary
*.gif         binary
*.pdf         binary
*.ico         binary
*.webp        binary
*.avif        binary

# SVG is text but treated as generated by some tooling
*.svg         text
*.svg         linguist-vendored=false

# License files — don't include in language stats
LICENSE       linguist-detectable=false
NOTICE        linguist-detectable=false
